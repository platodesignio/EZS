# =============================================================================
# Generative Power Space Explorer — Environment Variables
# Copy this file to .env.local for local development.
# =============================================================================

# PostgreSQL connection string (required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gpse"

# Required for Prisma connection pooling on Vercel (set to same as DATABASE_URL
# when not using a pooler like PgBouncer or Neon's pooled endpoint)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/gpse"

# App base URL (used for internal absolute fetches; set on Vercel automatically)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Mapbox token — OPTIONAL. If omitted the app uses free OpenStreetMap tiles.
# Get one at https://account.mapbox.com/ if you want Mapbox basemaps.
# NEXT_PUBLIC_MAPBOX_TOKEN="pk.ey..."

# Map style — set to a Mapbox style URL if NEXT_PUBLIC_MAPBOX_TOKEN is provided,
# otherwise leave as the default MapLibre OSM style shown below.
# NEXT_PUBLIC_MAP_STYLE="https://demotiles.maplibre.org/style.json"
